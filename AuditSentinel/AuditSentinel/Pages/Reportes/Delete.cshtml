@page "{id:int}"
@using Microsoft.AspNetCore.Authorization
@model AuditSentinel.Pages.Reportes.DeleteModel
@attribute [Authorize(Roles = "Administrador,Analista,Auditor")]
@{
    ViewData["Title"] = "Eliminar Reporte";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden" style="max-width: 500px; width: 100%;">

        <div class="bg-danger p-4 text-center text-white bg-gradient">
            <div class="mb-3">
                <i class="bi bi-file-earmark-x-fill shadow-sm" style="font-size: 3.5rem;"></i>
            </div>
            <h2 class="h4 fw-bold mb-0">¿Eliminar Reporte Final?</h2>
            <p class="small opacity-75 mb-0 text-uppercase tracking-wider">Esta acción es irreversible</p>
        </div>

        <div class="card-body p-4 text-center">
            <p class="text-muted mb-4">
                Usted está a punto de borrar permanentemente el consolidado de auditoría:
                <br>
                <span class="h5 fw-bold text-dark d-block mt-2">
                    <i class="bi bi-journal-text text-primary me-2"></i>@Model.Reporte.NombreReporte
                </span>
            </p>

            <div class="bg-light rounded-3 p-3 mb-4 border border-danger-subtle text-start">
                <div class="row g-2 small">
                    <div class="col-5 text-muted fw-bold text-uppercase">Cumplimiento:</div>
                    <div class="col-7 fw-bold text-dark">@Model.Reporte.cumplimiento</div>

                    <div class="col-5 text-muted fw-bold text-uppercase">Fecha Creación:</div>
                    <div class="col-7 text-dark">@Model.Reporte.Creado.ToString("yyyy-MM-dd HH:mm")</div>

                    <div class="col-5 text-muted fw-bold text-uppercase">Escaneos Vinculados:</div>
                    <div class="col-7">
                        <span class="badge bg-secondary rounded-pill px-3">
                            @((Model.Reporte.EscaneosReportes?.Count) ?? 0) Registros
                        </span>
                    </div>
                </div>
            </div>

            <form method="post">
                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg shadow-sm fw-bold py-2">
                        <i class="bi bi-trash3 me-2"></i>Confirmar Eliminación
                    </button>
                    <a asp-page="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-2"></i>Cancelar y Volver
                    </a>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="mt-3 text-danger x-small animate__animated animate__shakeX">
                        <i class="bi bi-info-circle me-1"></i> @Html.ValidationSummary(true)
                    </div>
                }
            </form>
        </div>

        <div class="card-footer bg-white border-top-0 py-3 text-center">
            <small class="text-muted italic" style="font-size: 0.75rem;">
                <i class="bi bi-shield-lock me-1"></i> AuditSentinel Data Integrity System
            </small>
        </div>
    </div>
</div>

<style>
    /* Estética de fondo para pantallas de eliminación */
    body {
        background-color: #f8f9fc;
        background-image: radial-gradient(circle at center, rgba(220, 53, 69, 0.05) 0%, transparent 80%);
    }

    /* Animación de la tarjeta al cargar */
    .card {
        animation: zoomIn 0.3s ease-out;
    }

    @@keyframes zoomIn {
        from {
            opacity: 0;
            transform: scale(0.95);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .x-small {
        font-size: 0.8rem;
    }

    .btn-danger {
        transition: all 0.2s ease;
    }

        .btn-danger:hover {
            background-color: #bb2d3b;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.25);
        }
</style>
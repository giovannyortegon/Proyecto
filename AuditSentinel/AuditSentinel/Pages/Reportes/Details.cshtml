@page "{id:int}"
@model AuditSentinel.Pages.Reportes.DetailsModel
@{
    ViewData["Title"] = "Expediente del Reporte";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-page="Index">Reportes</a></li>
                    <li class="breadcrumb-item active">Detalles del Informe</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">
                <i class="bi bi-file-earmark-bar-graph text-primary me-2"></i>Informe: @Model.Reporte.NombreReporte
            </h1>
        </div>
        <div class="d-flex gap-2">
            <a asp-page="Edit" asp-route-id="@Model.Reporte.IdReporte"
               class="btn btn-primary shadow-sm fw-bold">
                <i class="bi bi-pencil-square me-1"></i> Editar Reporte
            </a>

            @* ── Botón Exportar PDF ── *@
            <a asp-page-handler="ExportarPdf"
               asp-route-id="@Model.Reporte.IdReporte"
               class="btn btn-danger shadow-sm fw-bold">
                <i class="bi bi-file-earmark-pdf-fill me-1"></i> Exportar PDF
            </a>

            <button class="btn btn-outline-dark shadow-sm" onclick="window.print()">
                <i class="bi bi-printer me-1"></i> Imprimir
            </button>
            <a asp-page="Index" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Resumen de Cumplimiento</h6>
                </div>
                <div class="card-body">
                    <div class="text-center py-3">
                        @{
                            var cumplimiento = Model.Reporte.cumplimiento.ToString().ToLower();
                            var iconClass  = cumplimiento.Contains("alto") || cumplimiento.Contains("completo")
                                ? "text-success bi-shield-check"
                                : "text-warning bi-shield-exclamation";
                            var badgeClass = cumplimiento.Contains("alto") || cumplimiento.Contains("completo")
                                ? "bg-success"
                                : "bg-warning text-dark";
                        }
                        <i class="bi @iconClass" style="font-size: 4rem;"></i>
                        <h4 class="fw-bold mt-2">@Model.Reporte.cumplimiento</h4>
                        <span class="badge @badgeClass rounded-pill px-3">Estado de Auditoría</span>
                    </div>

                    <hr class="text-light">

                    <ul class="list-group list-group-flush small">
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted fw-bold text-uppercase">Referencia</span>
                            <span class="fw-bold">REP-@Model.Reporte.IdReporte.ToString("D4")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <span class="text-muted fw-bold text-uppercase">Fecha Creación</span>
                            <span>@Model.Reporte.Creado.ToString("f")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-dark">Evidencia Técnica (Escaneos Asociados)</h6>
                    <span class="badge bg-light text-primary border border-primary-subtle">
                        @Model.Reporte.EscaneosReportes.Count Escaneos
                    </span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light small text-uppercase fw-bold text-muted">
                                <tr>
                                    <th class="ps-4">Nombre del Escaneo</th>
                                    <th class="text-center">Estado de Ejecución</th>
                                    <th class="text-end pe-4">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var x in Model.Reporte.EscaneosReportes)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold text-dark">@x.Escaneos?.NombreEscaneo</div>
                                            <div class="x-small text-muted">ID: #@x.Escaneos?.IdEscaneo</div>
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var estado = x.Escaneos?.Estado.ToString();
                                                var eBadge = estado == "Finalizado"
                                                    ? "bg-success-subtle text-success border-success-subtle"
                                                    : "bg-light text-muted border";
                                            }
                                            <span class="badge @eBadge border px-2">@estado</span>
                                        </td>
                                        @* ── Ver fuente restaurado ── *@
                                        <td class="text-end pe-4">
                                            <a asp-page="/Escaneos/Details"
                                               asp-route-id="@x.Escaneos?.IdEscaneo"
                                               class="btn btn-sm btn-link text-decoration-none">
                                                Ver fuente
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .x-small { font-size: 0.75rem; }
    .bg-success-subtle     { background-color: #dcfce7 !important; }
    .border-success-subtle { border-color: #86efac !important; }

    @@media print {
        .btn, nav, .breadcrumb { display: none !important; }
        .card { border: 1px solid #ddd !important; }
        body  { background: white !important; }
    }
</style>

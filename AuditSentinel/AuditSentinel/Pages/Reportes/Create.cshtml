@page
@model AuditSentinel.Pages.Reportes.CreateModel
@{
    ViewData["Title"] = "Nuevo Reporte de Auditoría";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-page="Index" class="text-decoration-none">Reportes</a></li>
                    <li class="breadcrumb-item active">Nuevo Informe</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">
                <i class="bi bi-file-earmark-bar-graph-fill text-primary me-2"></i>Generar Reporte de Auditoría
            </h1>
        </div>
        <a asp-page="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver al listado
        </a>
    </div>

    <form method="post">
        <div class="row g-4">
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3 border-bottom border-primary border-3">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase small">Configuración General</h6>
                    </div>
                    <div class="card-body">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small shadow-sm mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="Reporte.NombreReporte" class="form-label small fw-bold text-muted text-uppercase">
                                Título del Informe <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-card-heading"></i></span>
                                <input asp-for="Reporte.NombreReporte" class="form-control bg-light border-start-0 ps-0"
                                       placeholder="Ej: Auditoría Trimestral de Infraestructura" />
                            </div>
                            <span asp-validation-for="Reporte.NombreReporte" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">
                                Estado de Cumplimiento Sugerido
                            </label>

                            <!-- Input oculto que envía el valor al servidor -->
                            <input type="hidden" asp-for="Reporte.cumplimiento" id="inputCumplimiento" value="0" />

                            <!-- Display visual automático -->
                            <div id="cumplimientoDisplay"
                                 class="rounded-3 px-4 py-3 d-flex align-items-center gap-3"
                                 style="background:#f1f5f9; border: 2px dashed #cbd5e1; min-height: 56px;">
                                <i class="bi bi-hourglass-split text-muted fs-5" id="cumplimientoIcono"></i>
                                <div>
                                    <div id="cumplimientoTexto" class="fw-bold text-muted">
                                        Selecciona escaneos para calcular
                                    </div>
                                    <div id="cumplimientoSub" class="small text-muted"></div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-0">
                            <label asp-for="Reporte.Creado" class="form-label small fw-bold text-muted text-uppercase">
                                Fecha de Emisión
                            </label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0"><i class="bi bi-calendar-date"></i></span>
                                <input asp-for="Reporte.Creado" type="datetime-local"
                                       class="form-control bg-light border-start-0 ps-0" />
                            </div>
                            <span asp-validation-for="Reporte.Creado" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h6 class="m-0 font-weight-bold text-primary text-uppercase small">Fuentes de Datos (Escaneos)</h6>
                        <span class="badge bg-primary rounded-pill shadow-sm">Paso Crítico</span>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">
                                Seleccionar Escaneos para Consolidar <span class="text-danger">*</span>
                            </label>

                            <select multiple
                                    id="selectEscaneos"
                                    class="form-select select-multiple-modern"
                                    asp-for="SelectedEscaneos"
                                    asp-items="Model.EscaneosList">
                            </select>

                            <span asp-validation-for="SelectedEscaneos" class="text-danger small d-block mt-2 fw-bold"></span>

                            <div class="alert alert-info border-0 mt-4 small d-flex align-items-start shadow-sm">
                                <i class="bi bi-info-circle-fill me-3 mt-1 fs-5"></i>
                                <div>
                                    <strong>Instrucciones:</strong> Mantenga presionada la tecla <strong>Ctrl</strong> (Windows)
                                    o <strong>Command</strong> (Mac) para seleccionar varios escaneos.
                                    El cumplimiento se calculará automáticamente según los estados seleccionados.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mt-4">
            <div class="card-body d-flex justify-content-between align-items-center py-3">
                <p class="small text-muted mb-0 italic">
                    <i class="bi bi-shield-fill-check me-1"></i> AuditSentinel Reporting Engine | Versión 2.5
                </p>
                <div class="d-flex gap-3">
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow fw-bold">
                        <i class="bi bi-cloud-arrow-up me-2"></i> Generar Reporte Final
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
    .select-multiple-modern {
        height: 280px !important;
        border-radius: 12px;
        background-color: #f8fafc;
        border: 2px dashed #cbd5e1;
        padding: 10px;
        transition: all 0.3s ease;
    }

        .select-multiple-modern:focus {
            border-color: #4e73df;
            border-style: solid;
            background-color: #fff;
            box-shadow: 0 0 0 0.25rem rgba(78, 115, 223, 0.1);
        }

        .select-multiple-modern option {
            padding: 12px 15px;
            margin-bottom: 6px;
            border-radius: 8px;
            transition: all 0.2s;
            border-left: 4px solid transparent;
            font-weight: 500;
            color: #475569;
        }

            .select-multiple-modern option:checked {
                background: linear-gradient(135deg, #4e73df 0%, #224abe 100%) !important;
                color: white !important;
                border-left: 4px solid #1e3a8a;
            }

    .input-group-text {
        border-radius: 10px 0 0 10px;
        color: #4e73df;
        background-color: #f8fafc;
        border-color: #dee2e6;
    }

    .form-control, .form-select {
        border-radius: 0 10px 10px 0;
    }

        .form-control:focus, .form-select:focus {
            border-color: #4e73df;
            background-color: #fff;
        }

    .breadcrumb-item a {
        color: #4e73df;
        font-weight: 500;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const selectEscaneos     = document.getElementById('selectEscaneos');
        const inputCumplimiento  = document.getElementById('inputCumplimiento');
        const display            = document.getElementById('cumplimientoDisplay');
        const displayTexto       = document.getElementById('cumplimientoTexto');
        const displaySub         = document.getElementById('cumplimientoSub');
        const displayIcono       = document.getElementById('cumplimientoIcono');

        selectEscaneos.addEventListener('change', calcularCumplimiento);

        function calcularCumplimiento() {
            const seleccionadas = Array.from(selectEscaneos.selectedOptions);

            if (seleccionadas.length === 0) {
                // Sin selección — estado neutro
                display.style.background = '#f1f5f9';
                display.style.border = '2px dashed #cbd5e1';
                displayIcono.className = 'bi bi-hourglass-split text-muted fs-5';
                displayTexto.className = 'fw-bold text-muted';
                displayTexto.textContent = 'Selecciona escaneos para calcular';
                displaySub.textContent = '';
                inputCumplimiento.value = '0';
                return;
            }

            // Extraer estado del texto: "Nombre (Estado)"
            const estados = seleccionadas.map(opt => {
                const match = opt.text.match(/\(([^)]+)\)$/);
                return match ? match[1].trim() : '';
            });

            const total          = estados.length;
            const completados    = estados.filter(e => e === 'Completado').length;
            const fallidos       = estados.filter(e => e === 'Fallido').length;

            if (completados === total) {
                // Todos Completado → Cumple
                inputCumplimiento.value = '@((int)AuditSentinel.Models.Cumplimiento.Cumple)';
                display.style.background = '#dcfce7';
                display.style.border = '2px solid #16a34a';
                displayIcono.className = 'bi bi-shield-fill-check text-success fs-4';
                displayTexto.className = 'fw-bold text-success';
                displayTexto.textContent = 'Cumple';
                displaySub.textContent = `Todos los escaneos completados (${completados}/${total})`;

            } else if (fallidos === total) {
                // Todos Fallido → No Cumple
                inputCumplimiento.value = '@((int)AuditSentinel.Models.Cumplimiento.NoCumple)';
                display.style.background = '#fee2e2';
                display.style.border = '2px solid #dc2626';
                displayIcono.className = 'bi bi-shield-fill-x text-danger fs-4';
                displayTexto.className = 'fw-bold text-danger';
                displayTexto.textContent = 'No Cumple';
                displaySub.textContent = `Todos los escaneos fallidos (${fallidos}/${total})`;

            } else {
                // Mezcla → Parcialmente Cumple
                inputCumplimiento.value = '@((int)AuditSentinel.Models.Cumplimiento.ParcialmenteCumple)';
                display.style.background = '#fef9c3';
                display.style.border = '2px solid #ca8a04';
                displayIcono.className = 'bi bi-shield-fill-exclamation text-warning fs-4';
                displayTexto.className = 'fw-bold text-warning';
                displayTexto.textContent = 'Parcialmente Cumple';
                displaySub.textContent = `${completados} completado(s), ${fallidos} fallido(s) de ${total}`;
            }
        }
    </script>
}

@page "{id}"
@using Microsoft.AspNetCore.Authorization
@model AuditSentinel.Pages.Registrar.CambiarPasswordModel
@attribute [Authorize(Roles = "Administrador")]


@{
    ViewData["Title"] = "Restablecer Contraseña";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 500px;">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i> Nueva Contraseña</h5>
        </div>
        <div class="card-body">
            <p class="text-muted small">Cambiar contraseña para: <strong>@Model.UserName</strong></p>

            <form method="post">
                <input type="hidden" asp-for="IdUsuario" />
                <div class="mb-3">
                    <label class="form-label small fw-bold">Nueva Contraseña</label>
                    <input asp-for="Password" class="form-control" type="password" required />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Confirmar Contraseña</label>
                    <input asp-for="ConfirmacionPassword" class="form-control" type="password" required />
                    <span asp-validation-for="ConfirmacionPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Actualizar Contraseña</button>
                    <a asp-page="./Editar" asp-route-id="@Model.IdUsuario" class="btn btn-link btn-sm text-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
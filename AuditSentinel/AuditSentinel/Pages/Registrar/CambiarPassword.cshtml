@page "{id}"
@using Microsoft.AspNetCore.Authorization
@model AuditSentinel.Pages.Registrar.CambiarPasswordModel
@attribute [Authorize(Roles = "Administrador")]


@{
    ViewData["Title"] = "Restablecer Contraseña";
    var usuarioId = Model.IdUsuario;
    var username = Model.UserName;
}

<div class="container-fluid py-4 ">
    <div class="d-flex justify-content-between align-items-center mb-4 text-bg-light p-3 rounded-3 shadow-sm">
        <div>
            <nav aria-label="breadcrumb text-dark">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-page="./Index" class="text-black-50">Usuarios</a></li>
                    <li class="breadcrumb-item active text-black" aria-current="page">Detalles</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 fw-bold text-dark">
                <i class="bi bi-person-badge me-2 text-dark"></i> Perfil de Usuario
            </h1>
        </div>
        <div class="d-flex flex-column gap-1">
            <span class="badge bg-white text-primary rounded-pill px-3 shadow-sm">Usuario: @username </span>
            <span class="badge bg-white text-primary rounded-pill px-3 shadow-sm">ID: @usuarioId </span>
        </div>
        <a asp-page="Editar" asp-route-id="@usuarioId" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Regresar
        </a>
    </div>
</div>

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto" style="max-width: 500px;">
        
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i> Nueva Contraseña</h5>
        </div>
        <div class="card-body">
            <p class="text-muted small">Cambiar contraseña para: <strong>@Model.UserName</strong></p>

            <form method="post">
                <input type="hidden" asp-for="IdUsuario" />

                <div class="mb-3">
                    <label class="form-label small fw-bold">Nueva Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-key"></i>
                        </span>
                        <input asp-for="Password" class="form-control border-start-0 border-end-0 ps-0" type="password" required />
                        <span class="input-group-text bg-light border-start-0 text-muted toggle-password" data-target="Password" style="cursor: pointer;" title="Mostrar/Ocultar contraseña">
                            <i class="bi bi-eye toggle-icon"></i>
                        </span>
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold">Confirmar Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-key"></i>
                        </span>
                        <input asp-for="ConfirmacionPassword" class="form-control border-start-0 border-end-0 ps-0" type="password" required />
                        <span class="input-group-text bg-light border-start-0 text-muted toggle-password" data-target="ConfirmacionPassword" style="cursor: pointer;" title="Mostrar/Ocultar contraseña">
                            <i class="bi bi-eye toggle-icon"></i>
                        </span>
                    </div>
                    <span asp-validation-for="ConfirmacionPassword" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-center mt-4">
                    <button type="submit" class="btn btn-primary fw-bold"
                            onclick="return confirm('¿Está seguro de confirmar el cambio de contraseña?');">
                        <i class="bi bi-check-circle me-2"></i> Confirmar cambios
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Seleccionamos todos los botones de "ver contraseña"
        const toggleButtons = document.querySelectorAll(".toggle-password");

        toggleButtons.forEach(button => {
            button.addEventListener("click", function () {
                // Obtenemos el ID del input asociado desde el data-target
                const targetId = this.getAttribute("data-target");
                const passwordInput = document.getElementById(targetId);
                const toggleIcon = this.querySelector(".toggle-icon");

                if (passwordInput) {
                    // Alternar el tipo de input (password <-> text)
                    const type = passwordInput.getAttribute("type") === "password" ? "text" : "password";
                    passwordInput.setAttribute("type", type);

                    // Alternar el ícono (ojo abierto <-> ojo cerrado)
                    if (type === "text") {
                        toggleIcon.classList.remove("bi-eye");
                        toggleIcon.classList.add("bi-eye-slash");
                    } else {
                        toggleIcon.classList.remove("bi-eye-slash");
                        toggleIcon.classList.add("bi-eye");
                    }
                }
            });
        });
    });
</script>
<style>

    .contenedor {
        position: relative;
        padding: 16px;
        border: 1px solid #ddd;
        border-radius: 6px;
    }

    .info-usuario {
        display: flex;
        flex-direction: column; /* uno debajo del otro */
        gap: 4px;
    }

    .usuario,
    .idusuario {
        font-size: 16px;
    }

    .link-esquina {
        position: absolute;
        top: 8px;
        right: 12px;
        color: #0d6efd;
        text-decoration: none;
        font-weight: 500;
    }

        .link-esquina:hover {
            text-decoration: underline;
        }
</style>
@page "/error/500"
@model AuditSentinel.Pages.Error.ServerErrorModel
@{
    Layout = null;
    ViewData["Title"] = "500 - Error Interno del Servidor";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-blue: #0a58ca;
            --danger-red: #dc3545;
            --dark-bg: #020617;
        }

        body {
            margin: 0;
            height: 100vh;
            background: radial-gradient(circle at center, #1e3a8a 0%, #020617 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: #f0f9ff;
            overflow: hidden;
        }

        .error-container {
            text-align: center;
            padding: 3rem;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            max-width: 550px;
            width: 90%;
            position: relative;
        }

        .error-code {
            font-size: 8rem;
            font-weight: 900;
            line-height: 1;
            margin: 0;
            background: linear-gradient(to bottom, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -2px;
            filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
        }

        /* Icono de Herramientas / Reparación */
        .icon-box {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 2rem auto;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .bi-gear-wide-connected {
            font-size: 4rem;
            color: #94a3b8;
            animation: spin 4s linear infinite;
        }

        .bi-wrench {
            position: absolute;
            font-size: 2rem;
            color: var(--primary-blue);
            bottom: 0;
            right: 10px;
            animation: wrench-move 2s ease-in-out infinite;
        }

        .oops {
            font-size: 2.5rem;
            font-weight: 800;
            margin-top: 1rem;
            color: #fff;
        }

        .message {
            font-size: 1.1rem;
            color: #94a3b8;
            margin: 1rem 0 2rem;
            line-height: 1.5;
        }

        .request-id {
            background: rgba(220, 53, 69, 0.1);
            padding: 0.75rem;
            border-radius: 0.75rem;
            font-family: monospace;
            font-size: 0.85rem;
            color: #ff8e8e;
            border: 1px solid rgba(220, 53, 69, 0.2);
            margin-bottom: 2rem;
        }

        .btn-home {
            display: inline-flex;
            align-items: center;
            background: var(--primary-blue);
            color: white;
            padding: 0.8rem 2.5rem;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 15px -3px rgba(10, 88, 202, 0.4);
        }

            .btn-home:hover {
                background: #084298;
                transform: translateY(-2px);
                box-shadow: 0 20px 25px -5px rgba(10, 88, 202, 0.5);
            }

        /* Animaciones escapadas para Razor */
        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        @@keyframes wrench-move {
            0%, 100% {
                transform: rotate(-10deg);
            }

            50% {
                transform: rotate(20deg);
            }
        }

        /* Líneas de circuito de fondo */
        .circuit-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(rgba(10, 88, 202, 0.1) 1px, transparent 1px);
            background-size: 30px 30px;
            z-index: -1;
        }
    </style>
</head>
<body>
    <div class="circuit-bg"></div>

    <div class="error-container">
        <div class="error-code">500</div>

        <div class="icon-box">
            <i class="bi bi-gear-wide-connected"></i>
            <i class="bi bi-wrench"></i>
        </div>

        <div class="oops">Error del Sistema</div>

        <p class="message">
            Nuestros servidores han detectado una anomalía interna. Estamos trabajando para restablecer el servicio de auditoría.
        </p>

        @if (!string.IsNullOrEmpty(Model.RequestId))
        {
            <div class="request-id">
                <i class="bi bi-bug me-2"></i> ID de Solicitud: @Model.RequestId
            </div>
        }

        <a href="/" class="btn-home">
            <i class="bi bi-arrow-left me-2"></i> Volver al Inicio
        </a>
    </div>
</body>
</html>
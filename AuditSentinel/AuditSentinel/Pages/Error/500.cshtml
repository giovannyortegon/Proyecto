@page "/error/500"
@model AuditSentinel.Pages.Error.ServerErrorModel
@{
    Layout = null;
    ViewData["Title"] = "500 - Error Crítico del Sistema";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-blue: #0a58ca;
            --danger-red: #dc3545;
            --light-bg: #ffffff;
            --text-dark: #1e293b;
            --text-muted: #64748b;
            --terminal-box-bg: #f8fafc;
        }

        body {
            margin: 0;
            height: 100vh;
            background-color: var(--light-bg);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: var(--text-dark);
            overflow: hidden;
        }

        /* Rejilla de fondo técnica sutil */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
            background-size: 45px 45px;
            z-index: -1;
        }

        /* Contenedor principal */
        .error-container {
            text-align: center;
            padding: 4rem;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 2rem;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.05);
            max-width: 550px;
            width: 90%;
            position: relative;
        }

        .error-code {
            font-size: 9rem;
            font-weight: 900;
            line-height: 0.8;
            margin: 0;
            color: var(--text-dark);
            letter-spacing: -5px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.05));
        }

        /* Caja de Alerta Técnica */
        .icon-box {
            position: relative;
            width: 110px;
            height: 110px;
            margin: 2.5rem auto;
            border: 2px solid rgba(220, 53, 69, 0.1);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: rgba(220, 53, 69, 0.02);
        }

            .icon-box::after {
                content: '';
                position: absolute;
                width: 100%;
                height: 100%;
                border: 2px solid var(--danger-red);
                border-radius: 50%;
                animation: pulse-red 2.5s infinite;
            }

        .bi-shield-exclamation {
            font-size: 3rem;
            color: var(--danger-red);
            z-index: 2;
        }

        .bi-cpu {
            position: absolute;
            font-size: 1.5rem;
            color: var(--primary-blue);
            top: 10px;
            right: 10px;
            animation: spin 6s linear infinite;
        }

        .oops {
            font-size: 1.8rem;
            font-weight: 800;
            margin-top: 1rem;
            color: var(--text-dark);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .message {
            font-size: 1rem;
            color: var(--text-muted);
            margin: 1.2rem 0 2.5rem;
            line-height: 1.6;
            max-width: 420px;
            margin-left: auto;
            margin-right: auto;
        }

        /* Caja de Trace ID estilo terminal */
        .path-box {
            background: var(--terminal-box-bg);
            padding: 0.85rem 1.25rem;
            border-radius: 0.75rem;
            font-family: 'Consolas', 'Monaco', monospace;
            font-size: 0.85rem;
            color: var(--danger-red);
            border: 1px solid #f1f5f9;
            margin-bottom: 3rem;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            background: var(--primary-blue);
            color: #fff;
            padding: 1rem 2.5rem;
            border-radius: 12px;
            font-weight: 700;
            text-decoration: none;
            border: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 1px;
            box-shadow: 0 4px 12px rgba(10, 88, 202, 0.2);
        }

            .btn-back:hover {
                background: #084298;
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(10, 88, 202, 0.3);
                color: #fff;
            }

        /* Animaciones escapadas */
        @@keyframes pulse-red {
            0% {
                transform: scale(1);
                opacity: 0.5;
            }

            100% {
                transform: scale(1.6);
                opacity: 0;
            }
        }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>
<body>
    <div class="bg-grid"></div>

    <div class="error-container">
        <div class="error-code">500</div>

        <div class="icon-box">
            <i class="bi bi-shield-exclamation"></i>
            <i class="bi bi-cpu"></i>
        </div>

        <div class="oops">Fallo del Sistema</div>

        <p class="message">
            Se ha detectado una anomalía crítica en el núcleo del servidor. Los protocolos de seguridad han aislado la sesión para proteger la integridad de los datos.
        </p>

        @if (!string.IsNullOrEmpty(Model.RequestId))
        {
            <div class="path-box">
                <i class="bi bi-bug-fill"></i>
                <span>TRACE_ID: @Model.RequestId</span>
            </div>
        }

        <br />

        <a href="/" class="btn-back">
            <i class="bi bi-shield-check me-2"></i> Volver a Inicio
        </a>
    </div>
</body>
</html>
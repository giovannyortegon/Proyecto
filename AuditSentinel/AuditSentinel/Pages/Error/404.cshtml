@page "/error/404"
@model AuditSentinel.Pages.Error.NotFoundModel
@{
    Layout = null;
    ViewData["Title"] = "404 - Recurso no encontrado";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        :root {
            --primary-blue: #0a58ca;
            --dark-navy: #020617;
            --accent-cyan: #22d3ee;
        }

        body {
            margin: 0;
            height: 100vh;
            background: radial-gradient(circle at center, #1e3a8a 0%, #020617 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: #f0f9ff;
            overflow: hidden;
        }

        /* Contenedor con efecto de profundidad */
        .error-container {
            text-align: center;
            padding: 3rem;
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 2rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            max-width: 500px;
            width: 90%;
            position: relative;
        }

        /* Código 404 con efecto de glitch sutil */
        .error-code {
            font-size: 8rem;
            font-weight: 900;
            line-height: 1;
            margin: 0;
            background: linear-gradient(to bottom, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -5px;
            position: relative;
        }

        /* Icono de Radar/Escaneo */
        .radar-box {
            position: relative;
            width: 120px;
            height: 120px;
            margin: 1.5rem auto;
            border: 2px solid var(--accent-cyan);
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 0 20px rgba(34, 211, 238, 0.2);
        }

            .radar-box::after {
                content: '';
                position: absolute;
                width: 100%;
                height: 100%;
                border: 1px solid var(--accent-cyan);
                border-radius: 50%;
                animation: pulse 2s infinite;
            }

        .bi-search {
            font-size: 3rem;
            color: var(--accent-cyan);
            animation: scan 3s infinite ease-in-out;
        }

        .oops {
            font-size: 2.5rem;
            font-weight: 800;
            margin-top: 1rem;
            color: #fff;
        }

        .message {
            font-size: 1.1rem;
            color: #94a3b8;
            margin: 1rem 0 2rem;
            line-height: 1.5;
        }

        .path-box {
            background: rgba(0, 0, 0, 0.3);
            padding: 0.75rem;
            border-radius: 0.75rem;
            font-family: monospace;
            font-size: 0.85rem;
            color: var(--accent-cyan);
            border: 1px solid rgba(34, 211, 238, 0.2);
            margin-bottom: 2rem;
            word-break: break-all;
        }

        /* Botón estilo AuditSentinel */
        .btn-back {
            display: inline-flex;
            align-items: center;
            background: var(--primary-blue);
            color: white;
            padding: 0.8rem 2rem;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 15px -3px rgba(10, 88, 202, 0.4);
        }

            .btn-back:hover {
                background: #084298;
                transform: translateY(-2px);
                box-shadow: 0 20px 25px -5px rgba(10, 88, 202, 0.5);
            }

        /* Animaciones */
        @@keyframes pulse {
            0%

        {
            transform: scale(1);
            opacity: 0.5;
        }

        100% {
            transform: scale(1.5);
            opacity: 0;
        }

        }

        @@keyframes scan {
            0%, 100%

        {
            transform: rotate(-10deg) scale(1);
        }

        50% {
            transform: rotate(10deg) scale(1.1);
        }

        }

        /* Fondo de partículas sutil */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(rgba(34, 211, 238, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(34, 211, 238, 0.05) 1px, transparent 1px);
            background-size: 50px 50px;
            z-index: -1;
        }
    </style>
</head>
<body>
    <div class="bg-grid"></div>

    <div class="error-container">
        <div class="error-code">404</div>

        <div class="radar-box">
            <i class="bi bi-search"></i>
        </div>

        <div class="oops">Recurso No Encontrado</div>

        <p class="message">
            El sistema de auditoría no ha podido localizar el objeto o página solicitada en el servidor.
        </p>

        @if (!string.IsNullOrEmpty(Model.OriginalPath))
        {
            <div class="path-box">
                <i class="bi bi-terminal me-2"></i> @Model.OriginalPath
            </div>
        }

        <a href="/" class="btn-back">
            <i class="bi bi-shield-check me-2"></i> Volver al Centro de Control
        </a>
    </div>
</body>
</html>
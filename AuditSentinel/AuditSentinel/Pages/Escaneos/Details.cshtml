@page "{id:int}"
@using Microsoft.AspNetCore.Authorization
@model AuditSentinel.Pages.Escaneos.DetailsModel
@attribute [Authorize(Roles = "Analista,Administrador")]

@{
    ViewData["Title"] = "Monitor de Escaneo";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-page="Index">Escaneos</a></li>
                    <li class="breadcrumb-item active">Monitor en Vivo</li>
                </ol>
            </nav>
            <h1 class="h3 mb-0 text-gray-800">
                <i class="bi bi-activity text-primary"></i> Escaneo: @Model.Escaneo.NombreEscaneo
            </h1>
        </div>
        <div class="btn-group shadow-sm">
            <a asp-page="Edit" asp-route-id="@Model.Escaneo.IdEscaneo" class="btn btn-white bg-white border">
                <i class="bi bi-pencil"></i> Editar
            </a>
            <a asp-page="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>
    </div>

    @* Fila de Identificación y Progreso *@
    <div class="card shadow-sm mb-4 border-0 border-start border-primary border-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-lg-3 border-end">
                    <div class="text-xs fw-bold text-primary text-uppercase mb-1">ID Operación</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">#@Model.Escaneo.IdEscaneo</div>
                    <div class="mt-2">
                        <span id="txtEstado" class="badge rounded-pill @(Model.Escaneo.Estado.ToString() == "Completado" ? "bg-success" : "bg-info") px-3">
                            @Model.Escaneo.Estado
                        </span>
                    </div>
                </div>

                <div class="col-lg-6 px-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold small text-muted">Progreso de Análisis de Vulnerabilidades</span>
                        <span id="progressText" class="fw-bold text-primary">0%</span>
                    </div>
                    <div class="progress shadow-sm" style="height: 12px; border-radius: 10px;">
                        <div id="pBar" class="progress-bar progress-bar-striped bg-primary"
                             role="progressbar" style="width: 0%; transition: width 0.5s ease;">
                        </div>
                    </div>
                    <div class="mt-2 small text-muted">
                        <i class="bi bi-calendar-event"></i> Iniciado: @Model.Escaneo.FechaEscaneo.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="col-lg-3 text-center">
                    <div id="btnGroupEscaneo">
                        <button id="btnStart" class="btn btn-primary btn-lg w-100 shadow-sm @(Model.Escaneo.Estado == AuditSentinel.Models.EstadoEscaneo.EnProgreso ? "d-none" : "")"
                                onclick="iniciarEscaneo()">
                            <i class="bi bi-play-circle-fill me-2"></i> Ejecutar Scan
                        </button>

                        <button id="btnStop" class="btn btn-outline-danger btn-lg w-100 @(Model.Escaneo.Estado == AuditSentinel.Models.EstadoEscaneo.EnProgreso ? "" : "d-none")"
                                onclick="detenerEscaneo()">
                            <i class="bi bi-stop-circle-fill me-2"></i> Abortar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Fila de Información General (Servidores, Reglas, Consola) *@
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 font-weight-bold text-dark"><i class="bi bi-server me-2"></i>Servidores Objetivo</h6>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var s in Model.Escaneo.EscaneosServidores)
                        {
                            <div class="list-group-item border-0 border-bottom">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-bold">@s.Servidores.NombreServidor</span>
                                    <code class="small px-2 py-1 bg-light rounded text-primary">@s.Servidores.IP</code>
                                </div>
                                <div class="d-flex justify-content-between mt-1">
                                    <div class="small text-muted">@s.Servidores.SistemaOperativo</div>
                                    <span id="status-@s.Servidores.NombreServidor" class="badge rounded-pill bg-secondary px-3">Cargando...</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-header bg-white py-3 border-0">
                    <h6 class="m-0 font-weight-bold text-dark"><i class="bi bi-shield-check me-2"></i>Reglas Aplicadas</h6>
                </div>
                <div class="card-body">
                    @foreach (var p in Model.Escaneo.EscaneosPlantillas)
                    {
                        <div class="d-flex align-items-center mb-3">
                            <div class="flex-shrink-0 bg-light p-2 rounded">
                                <i class="bi bi-file-earmark-ruled text-primary"></i>
                            </div>
                            <div class="ms-3">
                                <div class="fw-bold small">@p.Plantillas.NombrePlantilla</div>
                                <div class="text-muted" style="font-size: 0.75rem;">Configuración estándar</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-0 bg-dark">
                <div class="card-header bg-transparent py-3 border-0">
                    <h6 class="m-0 font-weight-bold text-white"><i class="bi bi-terminal me-2"></i>Consola de Actividad</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 280px;">
                        <table class="table table-dark table-sm table-hover mb-0" style="font-family: 'Courier New', Courier, monospace; font-size: 0.8rem;">
                            <tbody id="logTableBody">
                                <tr><td class="text-center text-muted p-4">Sistema listo para monitoreo...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* SECCIÓN DE RESULTADOS CON PAGINACIÓN Y SERVIDOR *@
    @if (Model.Escaneo.Estado == AuditSentinel.Models.EstadoEscaneo.Completado)
    {
        <div class="card shadow-sm border-0 animate__animated animate__fadeIn">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 text-primary fw-bold">
                    <i class="bi bi-list-check me-2"></i>Detalle de Hallazgos por Servidor
                </h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table id="tablaVulnerabilidades" class="table table-hover align-middle w-100">
                        <thead class="table-light">
                            <tr>
                                <th>Servidor</th>
                                <th>Vulnerabilidad</th>
                                <th>Riesgo</th>
                                <th>Estado</th>
                                <th>Fecha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Escaneo.EscaneosVulnerabilidades)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-hdd-network me-1"></i>
                                            @(Model.Escaneo.EscaneosServidores.FirstOrDefault()?.Servidores?.NombreServidor)
                                        </span>
                                    </td>
                                    <td>
                                        <div class="fw-bold text-dark">@item.Vulnerabilidades.NombreVulnerabilidad</div>
                                        <div class="text-muted small">@item.Vulnerabilidades.Descripcion</div>
                                    </td>
                                    <td>
                                        @{
                                            var badgeColor = item.Vulnerabilidades.NivelRiesgo switch
                                            {
                                                AuditSentinel.Models.NivelRiesgo.Critico => "bg-danger",
                                                AuditSentinel.Models.NivelRiesgo.Alto => "bg-warning text-dark",
                                                AuditSentinel.Models.NivelRiesgo.Medio => "bg-info text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeColor">@item.Vulnerabilidades.NivelRiesgo</span>
                                    </td>
                                    <td>
                                        @if (item.estado == AuditSentinel.Models.Estado.Activa)
                                        {
                                            <span class="badge bg-danger-soft text-danger border border-danger">
                                                <i class="bi bi-exclamation-triangle-fill me-1"></i> Detectada
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success-soft text-success border border-success">
                                                <i class="bi bi-check-circle-fill me-1"></i> Seguro
                                            </span>
                                        }
                                    </td>
                                    <td class="small text-muted">@item.FechaEscaneo.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <script src="https://code.jquery.com/jquery-3.7.0.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        $(document).ready(function () {
            $('#tablaVulnerabilidades').DataTable({
                "pageLength": 5,
                "lengthChange": false,
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                "dom": '<"d-flex justify-content-between mb-2"f>t<"d-flex justify-content-between mt-2"ip>'
            });
        });

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/escaneoHub")
            .withAutomaticReconnect()
            .build();

        connection.on("ReceiveUpdate", (data) => {
            const pBar = document.getElementById('pBar');
            const progressText = document.getElementById('progressText');
            if (pBar) pBar.style.width = data.porcentaje + '%';
            if (progressText) progressText.innerText = data.porcentaje + '%';

            const tbody = document.getElementById('logTableBody');
            if (tbody) {
                if (tbody.innerText.includes("Sistema listo")) tbody.innerHTML = "";
                const logRow = `<tr><td class="p-2 border-secondary">[DETECCIÓN] ${data.ultimaVuln} -> <span class="${data.estado == 'Activa' ? 'text-danger fw-bold' : 'text-success'}">${data.estado}</span></td></tr>`;
                tbody.insertAdjacentHTML('afterbegin', logRow);
            }

            if (data.esFinal || data.porcentaje >= 100) {
                setTimeout(() => { location.reload(); }, 2000);
            }
        });

        connection.on("AgentStatus", (hostname, isOnline) => {
            const el = document.getElementById('status-' + hostname);
            if (el) actualizarBadgeEstado(el, isOnline);
        });

        async function iniciarEscaneo() {
            document.getElementById('btnStart').classList.add('d-none');
            document.getElementById('btnStop').classList.remove('d-none');
            document.getElementById('pBar').classList.add('progress-bar-animated');
            document.getElementById('txtEstado').innerText = "Ejecutando...";

            await fetch(`?handler=Iniciar&id=@Model.Escaneo.IdEscaneo`, {
                method: 'POST',
                headers: { "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value }
            });
        }

        function actualizarBadgeEstado(el, isOnline) {
            el.innerText = isOnline ? "Online" : "Offline";
            el.className = isOnline ? "badge rounded-pill bg-success px-3" : "badge rounded-pill bg-secondary px-3";
        }

        connection.start().then(() => {
            connection.invoke("JoinScanGroup", @Model.Escaneo.IdEscaneo);
            @foreach (var item in Model.Escaneo.EscaneosServidores)
            {
                    <text>
                    connection.invoke("IsServerOnline", "@item.Servidores.NombreServidor").then(isOnline => {
                        const el = document.getElementById('status-@item.Servidores.NombreServidor');
                        if (el) actualizarBadgeEstado(el, isOnline);
                    });
                    </text>
            }
        });
    </script>

    <style>
        .bg-danger-soft {
            background-color: #fee2e2;
            color: #dc2626;
        }

        .bg-success-soft {
            background-color: #dcfce7;
            color: #16a34a;
        }

        .dataTables_info, .dataTables_paginate {
            font-size: 0.85rem;
        }
    </style>
}
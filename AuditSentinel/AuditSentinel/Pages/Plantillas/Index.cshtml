@page
@using Microsoft.AspNetCore.Authorization
@model AuditSentinel.Pages.Plantillas.IndexModel
@attribute [Authorize(Roles = "Analista,Administrador")]
@{
    ViewData["Title"] = "Gestión de Plantillas";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="bi bi-file-earmark-medical-fill text-primary"></i> Catálogo de Plantillas
        </h1>
        <div class="d-flex gap-2">
            <a asp-page="/Configuracion" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
            <a class="btn btn-primary shadow-sm px-4" asp-page="Create">
                <i class="bi bi-plus-lg me-1"></i> Nueva Plantilla
            </a>
        </div>
    </div>

  
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label small fw-bold text-muted">Buscar por Versión</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-search"></i></span>
                        <input name="Search" value="@Model.Search" class="form-control bg-light border-start-0 ps-0" placeholder="Ej: v2.0..." />
                    </div>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1" type="submit">Filtrar</button>
                    <a asp-page="./Index" class="btn btn-outline-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

  
    <div class="card shadow-sm border-0 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small fw-bold">
                        <tr>
                            <th class="ps-4">SISTEMA OPERATIVO</th>
                            <th class="text-center">VERSIÓN</th>
                            <th class="text-center">VULNERABILIDADES</th>
                            <th class="text-end pe-4">ACCIONES</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            foreach (var p in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-3 bg-light text-primary rounded d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                                <i class="bi bi-pc-display fs-5"></i>
                                            </div>
                                            <div>
                                                @* Muestra el DisplayName del Enum  *@
                                                <div class="fw-bold text-dark">@Html.DisplayFor(m => p.NombrePlantilla)</div>
                                                <small class="text-muted">ID: #@p.IdPlantilla</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary-subtle text-secondary border rounded-pill">
                                            @p.Version
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-circle bg-primary bg-opacity-10 text-primary border p-2" style="width: 35px; height: 35px; display: inline-flex; align-items: center; justify-content: center;">
                                            @(p.PlantillasVulnerabilidades?.Count ?? 0)
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-page="Details" asp-route-id="@p.IdPlantilla" class="btn btn-sm btn-outline-secundary"><i class="bi bi-info-circle"></i></a>
                                            <a asp-page="Edit" asp-route-id="@p.IdPlantilla" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                            <a asp-page="Delete" asp-route-id="@p.IdPlantilla" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">No se encontraron plantillas.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @* Paginación omitida por brevedad, se mantiene igual a tu archivo original [cite: 33-40] *@
    </div>
</div>